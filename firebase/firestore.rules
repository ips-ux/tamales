rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    /*
      Bangin Bustos Tamales runs on the free Firebase Spark plan, so there is no
      Cloud Functions / Admin SDK layer. The owner-only Live POS reads and writes
      Firestore directly from the browser, gated by the `admin: true` custom claim.

      Everything is denied by default. Only collections explicitly matched below
      are reachable, and only by an authenticated admin. The public preorder flow
      is intentionally not exposed here yet; add narrowly-scoped rules for it when
      that surface goes live.
    */

    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    // Live POS sales. Owner-only, full access.
    match /posTickets/{ticketId} {
      allow read, write: if isAdmin();
    }

    // Owner-editable business settings (timezone, tax rate, contact info).
    // Publicly readable so the customer site can show current contact details;
    // only the owner can change them.
    match /settings/business {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Default deny for anything not matched above.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

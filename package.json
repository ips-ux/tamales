{
  "name": "bangin-bustos-tamales",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -p tsconfig.json && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "firebase:env": "npm --prefix functions run write-web-env",
    "firebase:env:create": "npm --prefix functions run write-web-env -- --create-if-missing",
    "seed": "npm --prefix functions run seed",
    "functions:build": "npm --prefix functions run build",
    "deploy": "npm run build && npm --prefix functions run build && firebase deploy"
  },
  "dependencies": {
    "firebase": "^11.0.0",
    "lucide-react": "^0.468.0",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "@types/node": "^24.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.8.0",
    "vite": "^7.0.0",
    "vitest": "^3.2.0"
  }
}
